{
  "name": "portfolio-api",
  "version": "0.1.0",
  "private": true,
  "description": "Azure Functions API for Personal Portfolio Management",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "storage:start": "azurite --silent --location .azurite --skipApiVersionCheck",
    "storage:start:docker": "docker compose up -d azurite",
    "storage:stop:docker": "docker compose down",
    "cosmos:start:docker": "docker compose up -d cosmos-emulator",
    "sql:start:docker": "docker compose up -d sqlserver",
    "dev:deps": "docker compose up -d azurite cosmos-emulator sqlserver",
    "db:wait": "docker compose exec -T sqlserver bash -c 'until /opt/mssql-tools18/bin/sqlcmd -S localhost -U sa -P \"$MSSQL_SA_PASSWORD\" -C -Q \"SELECT 1\" >/dev/null 2>&1; do sleep 2; done'",
    "db:ensure": "bash scripts/db-ensure.sh",
    "db:migrate": "npm run db:ensure && docker run --rm --network host -v \"$(pwd)/db:/liquibase/changelog\" -w /liquibase/changelog liquibase/liquibase:4.31 --defaults-file=liquibase.properties update",
    "db:status": "docker run --rm --network host -v \"$(pwd)/db:/liquibase/changelog\" -w /liquibase/changelog liquibase/liquibase:4.31 --defaults-file=liquibase.properties status",
    "db:import-disk": "npm run build && node dist/src/scripts/importDiskTransactions.js",
    "start": "func start",
    "prestart": "npm run build",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/cosmos": "^4.2.0",
    "@azure/functions": "^4.6.0",
    "@azure/identity": "^4.8.0",
    "@azure/keyvault-secrets": "^4.9.0",
    "@azure/storage-queue": "^12.25.0",
    "@portfolio/contracts": "file:../portfolio-contracts",
    "@portfolio/tax-engine": "file:../portfolio-tax-engine",
    "mssql": "^11.0.1"
  },
  "devDependencies": {
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.13.10",
    "azure-functions-core-tools": "^4.0.6280",
    "azurite": "^3.35.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=20"
  }
}
