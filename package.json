{
  "name": "portfolio-api",
  "version": "0.1.0",
  "private": true,
  "description": "Azure Functions API for Personal Portfolio Management",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "storage:start": "azurite --silent --location .azurite --skipApiVersionCheck",
    "cosmos:azure": "bash scripts/cosmos-azure-local.sh",
    "sql:azure": "bash scripts/sql-azure-local.sh",
    "secrets:azure-local": "bash scripts/secrets-azure-local.sh",
    "azure:local": "npm run cosmos:azure && npm run sql:azure",
    "sql:verify": "bash scripts/sql-verify.sh",
    "dev:check": "bash scripts/dev-check.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "db:status": "bash scripts/db-migrate.sh status",
    "db:import-disk": "npm run build && node dist/src/scripts/importDiskTransactions.js",
    "deploy": "bash scripts/deploy.sh",
    "deploy:dev": "bash scripts/deploy.sh dev",
    "deploy:prod": "bash scripts/deploy.sh prod",
    "start": "func start",
    "prestart": "npm run build && bash scripts/require-azurite.sh",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/cosmos": "^4.2.0",
    "@azure/functions": "^4.6.0",
    "@azure/identity": "^4.8.0",
    "@azure/keyvault-secrets": "^4.9.0",
    "@azure/storage-queue": "^12.25.0",
    "@portfolio/contracts": "file:../portfolio-contracts",
    "@portfolio/tax-engine": "file:../portfolio-tax-engine",
    "jose": "^6.2.3",
    "mssql": "^11.0.1"
  },
  "devDependencies": {
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.13.10",
    "azure-functions-core-tools": "^4.0.6280",
    "azurite": "^3.35.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=20"
  }
}
