# Copy to local.settings.json Values or Azure App Settings.
# See env/README.md and env/*.values.example.json for per-environment templates.

APP_ENV=local
API_PUBLIC_BASE_URL=http://localhost:7071
WEB_APP_URL=http://localhost:3000
DEFAULT_HOUSEHOLD_ID=local-household

# SimpleFIN Access URL (after claiming setup token). Leave empty to use Connections UI.
SIMPLEFIN_ACCESS_URL=
SIMPLEFIN_ACCESS_URL__LOCAL_HOUSEHOLD=

# SnapTrade
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_WEBHOOK_SECRET=
SNAPTRADE_REDIRECT_URL=http://localhost:7071/api/integrations/snaptrade/callback

# Storage / Azure
COSMOS_ENDPOINT=https://localhost:8081
COSMOS_KEY=
COSMOS_DATABASE=portfolio
KEY_VAULT_NAME=
AzureWebJobsStorage=UseDevelopmentStorage=true
PORTFOLIO_QUEUE_NAME=portfolio-sync
# Storage: Cosmos DB (accounts, holdings, households) + Azure SQL (transactions)
STORAGE_MODE=cosmos

# Azure SQL (local Docker — see npm run dev:deps)
AZURE_SQL_SERVER=localhost
AZURE_SQL_DATABASE=portfolio
AZURE_SQL_USER=sa
AZURE_SQL_PASSWORD=PortfolioDev1!
AZURE_SQL_ENCRYPT=false
# Or full connection string (overrides parts above):
# AZURE_SQL_CONNECTION_STRING=Server=localhost,1433;Database=portfolio;User Id=sa;Password=PortfolioDev1!;Encrypt=false;TrustServerCertificate=true
